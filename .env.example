# Event Monitor Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Ethereum Node Connection
# ============================================
# Get this from Infura.io or Alchemy.com (free tier available)
# Format: wss://sepolia.infura.io/ws/v3/YOUR_PROJECT_ID
WEB3J_CLIENT_ADDRESS=wss://sepolia.infura.io/ws/v3/4f78d740f44c4389b6a7a873fe73fdc1


# ERC20 contract address to monitor
# Example USDC on Sepolia: 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
CONTRACT_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# ============================================
# OPTIONAL - Database Configuration
# ============================================
# Local PostgreSQL (default values)
DATABASE_URL=jdbc:postgresql://localhost:5432/eventmonitor
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ============================================
# OPTIONAL - Application Configuration
# ============================================
# Starting block for event monitoring
# Use "latest" to start from current block, or a specific block number
START_BLOCK=latest

# Spring profile (dev, prod, test)
SPRING_PROFILES_ACTIVE=dev

# ============================================
# How to use this file:
# ============================================
# 1. Copy to .env:
#    cp .env.example .env
#
# 2. Edit .env with your values:
#    nano .env
#
# 3. Source it before running:
#    source .env
#    ./run-local.sh
#
# Or use direnv to auto-load:
#    brew install direnv
#    echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc
#    direnv allow
