# Example secret configuration
# Copy this file to secret.yml and replace the values with base64-encoded secrets
# Example: echo -n "your-password" | base64

apiVersion: v1
kind: Secret
metadata:
  name: event-monitor-secret
  namespace: event-monitor
type: Opaque
data:
  # PostgreSQL password (base64 encoded)
  database.password: cG9zdGdyZXM=  # "postgres" - CHANGE THIS

  # Infura WebSocket URL (base64 encoded)
  # Format: wss://sepolia.infura.io/ws/v3/YOUR_PROJECT_ID
  infura.websocket.url: d3NzOi8vc2Vwb2xpYS5pbmZ1cmEuaW8vd3MvdjMvWU9VUl9QUk9KRUNUX0lE

  # ERC20 Contract address to monitor (base64 encoded)
  contract.address: MHgxMjM0NTY3ODkwMTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkw
